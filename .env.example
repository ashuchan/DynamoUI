# DynamoUI environment configuration
# Copy this file to .env and fill in your values.
# Real environment variables always take precedence over .env.

# ---------------------------------------------------------------------------
# PostgreSQL connection (DYNAMO_PG_*)
# ---------------------------------------------------------------------------

# Server
DYNAMO_PG_HOST=localhost
DYNAMO_PG_PORT=5432
DYNAMO_PG_DATABASE=dynamoui

# Read-only user — used for all SELECT queries
DYNAMO_PG_USER=dynamoui_reader
DYNAMO_PG_PASSWORD=

# Write user — used only for mutation operations
DYNAMO_PG_WRITE_USER=dynamoui_writer
DYNAMO_PG_WRITE_PASSWORD=

# Connection pool
DYNAMO_PG_POOL_SIZE=10
DYNAMO_PG_MAX_OVERFLOW=20
DYNAMO_PG_POOL_TIMEOUT=30
DYNAMO_PG_POOL_RECYCLE=3600

# SSL: disable | allow | prefer | require | verify-ca | verify-full
# Use "require" in production
DYNAMO_PG_SSL_MODE=prefer

# Set to true to log all SQL (dev only)
DYNAMO_PG_ECHO_SQL=false

# ---------------------------------------------------------------------------
# Skill Registry (DYNAMO_SKILL_*)
# ---------------------------------------------------------------------------

DYNAMO_SKILL_SKILLS_DIR=./skills
DYNAMO_SKILL_ENUMS_DIR=./enums
DYNAMO_SKILL_ADAPTERS_REGISTRY=./adapters.registry.yaml
DYNAMO_SKILL_REST_PORT=8001

# JWT signing secret — MUST be changed before deploying to production
DYNAMO_SKILL_JWT_SECRET=dev-insecure-change-me

DYNAMO_SKILL_LOG_LEVEL=INFO
# Log format: json | console
DYNAMO_SKILL_LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Pattern Cache (DYNAMO_CACHE_*)
# ---------------------------------------------------------------------------

DYNAMO_CACHE_FUZZY_THRESHOLD=0.90
DYNAMO_CACHE_ENTITY_SCOPED_MATCHING=true
DYNAMO_CACHE_ENFORCE_SKILL_HASH=true
